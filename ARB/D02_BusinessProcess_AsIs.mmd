flowchart LR
    classDef erpStyle  fill:#FADBD8,stroke:#C0392B,color:#1A0808,stroke-width:2px
    classDef procStyle fill:#D6EAF8,stroke:#1A5276,color:#0A2035,stroke-width:2px
    classDef finStyle  fill:#D5F5E3,stroke:#1E6823,color:#0A2D0F,stroke-width:2px
    classDef leadStyle fill:#EBD5F7,stroke:#512E5F,color:#200A2A,stroke-width:2px
    classDef painStyle fill:#F8F9FA,stroke:#E74C3C,color:#C0392B,stroke-width:1px,stroke-dasharray:5 3

    subgraph SAP["SAP / ERP System"]
        S1["SAP MM / FI Modules"]
        S2["Standard SAP Reports"]
        S1 --> S2
    end

    subgraph PROC["Procurement Team"]
        P1["Manual Excel\nExtract — T+1 to T+5"]
        P2["Consolidate Multiple\nDisconnected Reports"]
        P3["Weekly Email Report\nto Leadership"]
        P1 --> P2 --> P3
    end

    subgraph FIN["Finance / AP Team"]
        F1["Manual Invoice\nReconciliation"]
        F2["CAPEX / OPEX in\nShared Spreadsheet"]
        F1 --> F2
    end

    subgraph LEAD["Leadership / CXO"]
        L1["Receive Stale\nEmail Report"]
        L2["Request Further\nAnalysis — T+2 to T+5"]
        L3["Decisions on\nIncomplete Data"]
        L1 --> L2 --> L3
    end

    subgraph PAIN["Pain Points"]
        G1["No Real-Time Visibility"]
        G2["Anomalies Found\nOnly in Audit"]
        G3["No Central\nVendor View"]
    end

    S2 -->|Manual Extract| P1
    S2 -->|FI Reports| F1
    P3 --> L1
    P2 -.->|Gap| G1
    P2 -.->|Gap| G2
    F2 -.->|Gap| G3

    class S1,S2 erpStyle
    class P1,P2,P3 procStyle
    class F1,F2 finStyle
    class L1,L2,L3 leadStyle
    class G1,G2,G3 painStyle
