flowchart LR
    classDef moduleStyle fill:#FDEBD0,stroke:#B7770D,color:#3D1F03,stroke-width:2px
    classDef dataStyle   fill:#F5EEF8,stroke:#512E5F,color:#2C0A3A,stroke-width:2px
    classDef readStyle   fill:#D6EAF8,stroke:#1A5276,color:#0A2035,stroke-width:2px

    subgraph MODULES["Application Modules"]
        ETL["ETL Pipeline\nUpload Service"]
        KPI["KPI Engine"]
        VEND_SVC["Vendor Service"]
        AUTH["Auth & Admin\nModule"]
    end

    subgraph DATA["Data Domains"]
        TD[("Transactional Data\nPR · PO · GRN · Invoice · Payment")]
        VM[("Vendor Master")]
        AN[("Analytics\nKPI Results · P2P Facts · Anomalies")]
        PL[("Platform\nUsers · Audit Log")]
    end

    subgraph CONSUMERS["Dashboard Consumers"]
        DASH["Procurement &\nFinance Dashboards"]
        ANLYT["P2P Analytics\nView"]
        ADMIN_UI["Admin\nConsole"]
    end

    ETL      -->|"C · D (per upload)"| TD
    ETL      -->|"C · D (per upload)"| VM
    KPI      -->|"R"| TD
    KPI      -->|"C · U"| AN
    VEND_SVC -->|"C · R · U"| VM
    AUTH     -->|"C · R · U · D"| PL

    AN  --> DASH
    AN  --> ANLYT
    TD  --> DASH
    PL  --> ADMIN_UI

    class ETL,KPI,VEND_SVC,AUTH moduleStyle
    class TD,VM,AN,PL dataStyle
    class DASH,ANLYT,ADMIN_UI readStyle
