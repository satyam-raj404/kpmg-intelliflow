flowchart LR
    classDef erpStyle   fill:#FADBD8,stroke:#C0392B,color:#1A0808,stroke-width:2px
    classDef adminStyle fill:#FDEBD0,stroke:#B7770D,color:#3D1F03,stroke-width:2px
    classDef platStyle  fill:#D6EAF8,stroke:#1A5276,color:#0A2035,stroke-width:2px
    classDef userStyle  fill:#D5F5E3,stroke:#1E6823,color:#0A2D0F,stroke-width:2px

    subgraph ERP["ERP System"]
        S1["Export P2P Data\nas CSV"]
    end

    subgraph ADMIN["Admin / Data Specialist"]
        A1["Upload CSV\nvia Portal"]
        A2{"Validate\n& Process"}
        A3["Load to Database\n& Compute KPIs"]
        A1 --> A2
        A2 -->|Valid| A3
        A2 -->|Rejected| A4["Rejection\nReport"]
    end

    subgraph PLATFORM["IntelliSource Platform"]
        P1["Procurement\nDashboard"]
        P2["Finance\nDashboard"]
        P3["Compliance\nAlerts"]
        P4["Leadership\nDashboard"]
    end

    subgraph USERS["Business Users"]
        U1["Procurement\nManager"]
        U2["Finance\nUser"]
        U3["Compliance\nOfficer"]
        U4["Leadership\n/ CXO"]
    end

    S1 -->|Batch CSV| A1
    A3 --> P1
    A3 --> P2
    A3 --> P3
    A3 --> P4
    P1 --> U1
    P2 --> U2
    P3 --> U3
    P4 --> U4

    class S1 erpStyle
    class A1,A2,A3,A4 adminStyle
    class P1,P2,P3,P4 platStyle
    class U1,U2,U3,U4 userStyle
