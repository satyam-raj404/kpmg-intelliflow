flowchart TD
    classDef userStyle fill:#EBF5FB,stroke:#1565C0,color:#0A1E4A,stroke-width:2px
    classDef spaStyle  fill:#D6EAF8,stroke:#1A5276,color:#0A2035,stroke-width:2px
    classDef apiStyle  fill:#D5F5E3,stroke:#1E6823,color:#0A2D0F,stroke-width:2px
    classDef okStyle   fill:#D5F5E3,stroke:#1E6823,color:#0A2D0F,stroke-width:2px
    classDef failStyle fill:#FADBD8,stroke:#C0392B,color:#1A0808,stroke-width:2px
    classDef aadStyle  fill:#EBD5F7,stroke:#512E5F,color:#200A2A,stroke-width:2px
    classDef noteStyle fill:#FEF9E7,stroke:#D4AC0D,color:#3D2B00,stroke-width:1px,stroke-dasharray:4 2

    USER["KPMG User"]

    subgraph BASELINE["Current — Email & Password Login"]
        L1["Enter Credentials\non Login Page"]
        L2["POST /api/auth/login"]
        L3{"Validate Against\nUser Store"}
        L4["Access Granted\nRole-based Session"]
        L5["401 Unauthorised\nAccess Denied"]
        L1 --> L2 --> L3
        L3 -->|Valid| L4
        L3 -->|Invalid| L5
    end

    subgraph TARGET["Target — Azure AD SSO + MFA"]
        T1["Click Sign In\nwith KPMG SSO"]
        T2["Redirect to\nAzure AD"]
        T3["KPMG Credentials\n+ MFA Prompt"]
        T4["OAuth 2.0 Token\nIssued"]
        T5["Role Mapped\nAccess Granted"]
        T1 --> T2 --> T3 --> T4 --> T5
    end

    AUDITLOG["Audit Log\nAll login events recorded"]

    USER --> L1
    USER --> T1
    L4 --> AUDITLOG
    L5 --> AUDITLOG
    T5 --> AUDITLOG

    class USER userStyle
    class L1,L2 spaStyle
    class L3 apiStyle
    class L4,T4,T5 okStyle
    class L5 failStyle
    class T1,T2,T3 aadStyle
    class AUDITLOG noteStyle
