erDiagram
    PURCHASE_REQUISITION {
        string id PK
        string requisitioner
        string material_group
        date   delivery_date
    }
    PURCHASE_ORDER {
        string id PK
        string vendor FK
        string pr_reference FK
        decimal value
        string status
    }
    GOODS_RECEIPT {
        string id PK
        string po_reference FK
        decimal quantity
        date   posting_date
    }
    INVOICE {
        string id PK
        string vendor FK
        string po_reference FK
        decimal amount
        date   due_date
    }
    PAYMENT {
        string id PK
        string invoice_ref FK
        decimal amount
        date   clearing_date
    }
    VENDOR {
        string code PK
        string name
        string country
        string msme_flag
        string payment_terms
    }
    P2P_ANALYTICS {
        string po_reference PK
        int    cycle_days
        string anomaly_flags
        string variant_class
    }
    KPI_RESULTS {
        string dashboard PK
        string kpi_code   PK
        decimal value
        timestamp computed_at
    }

    PURCHASE_REQUISITION ||--o{ PURCHASE_ORDER    : "fulfilled by"
    PURCHASE_ORDER       ||--o{ GOODS_RECEIPT      : "received via"
    PURCHASE_ORDER       ||--o{ INVOICE            : "billed against"
    INVOICE              ||--o{ PAYMENT            : "settled by"
    VENDOR               ||--o{ PURCHASE_ORDER     : "fulfills"
    VENDOR               ||--o{ INVOICE            : "submits"
    PURCHASE_ORDER       ||--|| P2P_ANALYTICS      : "analyzed in"
    P2P_ANALYTICS        ||--o{ KPI_RESULTS        : "aggregated into"
