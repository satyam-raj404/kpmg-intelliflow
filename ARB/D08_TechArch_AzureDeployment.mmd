flowchart TD
    classDef userStyle fill:#EBF5FB,stroke:#1565C0,color:#0A1E4A,stroke-width:2px
    classDef edgeStyle fill:#D6EAF8,stroke:#1A5276,color:#0A2035,stroke-width:2px
    classDef appStyle  fill:#D5F5E3,stroke:#1E6823,color:#0A2D0F,stroke-width:2px
    classDef dataStyle fill:#F5EEF8,stroke:#512E5F,color:#2C0A3A,stroke-width:2px
    classDef idStyle   fill:#EBD5F7,stroke:#512E5F,color:#200A2A,stroke-width:2px
    classDef opsStyle  fill:#FDEBD0,stroke:#B7770D,color:#3D1F03,stroke-width:2px
    classDef ciStyle   fill:#FEF9E7,stroke:#D4AC0D,color:#3D2B00,stroke-width:2px
    classDef extStyle  fill:#FADBD8,stroke:#C0392B,color:#1A0808,stroke-width:2px

    subgraph INTERNET["Internet"]
        USR["KPMG Staff\nWeb Browser"]
        SAP_OP["SAP Admin\nCSV Upload"]
    end

    subgraph EDGE["Azure Edge"]
        CDN["Static Web App\nReact SPA · CDN"]
        AGW["Application Gateway\n+ WAF"]
    end

    subgraph APP_ZONE["Azure Application Zone"]
        ACA["Container App\nFastAPI · Python"]
        ACR["Container Registry"]
    end

    subgraph DATA_ZONE["Azure Data Zone"]
        PG[("PostgreSQL\nFlexible Server")]
        KV["Key Vault\nSecrets"]
    end

    subgraph IDENTITY["Azure Identity"]
        AAD["Azure Active Directory\nSSO · MFA · RBAC"]
    end

    subgraph OPS["Azure Operations"]
        MON["Azure Monitor\n+ App Insights"]
        LOG["Log Analytics"]
    end

    subgraph CICD["CI / CD"]
        GH["GitHub\nSource & Pipelines"]
    end

    USR     -->|"HTTPS"| CDN
    USR     -->|"HTTPS"| AGW
    SAP_OP  -->|"CSV Upload · HTTPS"| AGW
    CDN     --> AGW
    AGW     -->|"Internal HTTPS"| ACA
    ACA     <-->|"TLS · Port 5432"| PG
    ACA     -->|"Managed Identity"| KV
    AAD     -->|"OAuth 2.0 Tokens"| ACA
    GH      -->|"Docker Push"| ACR
    GH      -->|"Deploy SPA"| CDN
    ACR     -->|"Image Pull"| ACA
    ACA     --> MON
    ACA     --> LOG
    PG      --> LOG

    class USR,SAP_OP userStyle
    class CDN,AGW edgeStyle
    class ACA,ACR appStyle
    class PG,KV dataStyle
    class AAD idStyle
    class MON,LOG opsStyle
    class GH ciStyle
