flowchart TD
    classDef hdrStyle fill:#0D1F35,stroke:#0D1F35,color:#FFFFFF,stroke-width:0px
    classDef feStyle  fill:#D6EAF8,stroke:#1A5276,color:#0A2035,stroke-width:2px
    classDef beStyle  fill:#D5F5E3,stroke:#1E6823,color:#0A2D0F,stroke-width:2px
    classDef dbStyle  fill:#F5EEF8,stroke:#512E5F,color:#2C0A3A,stroke-width:2px
    classDef devStyle fill:#FDEBD0,stroke:#B7770D,color:#3D1F03,stroke-width:2px

    HDR["Technology Stack — IntelliSource"]

    subgraph COL_FE["Frontend"]
        FE_L["TypeScript"]
        FE_F["React · Vite"]
        FE_U["shadcn/ui · Tailwind CSS"]
        FE_S["TanStack Router · TanStack Query"]
        FE_H["Azure Static Web App / Vercel"]
    end

    subgraph COL_BE["Backend"]
        BE_L["Python 3.11+"]
        BE_F["FastAPI · Uvicorn"]
        BE_D["psycopg3"]
        BE_L2["openpyxl · httpx"]
        BE_H["Azure Container Apps"]
    end

    subgraph COL_DB["Database"]
        DB_A["PostgreSQL 15+"]
        DB_H["Azure DB for PostgreSQL\nFlexible Server"]
        DB_S["Azure Key Vault\n(Secrets)"]
    end

    subgraph COL_DEV["DevOps"]
        DEV_S["GitHub"]
        DEV_C["GitHub Actions"]
        DEV_R["Azure Container Registry"]
        DEV_M["Azure Monitor\n+ App Insights"]
    end

    HDR --> COL_FE
    HDR --> COL_BE
    HDR --> COL_DB
    HDR --> COL_DEV

    class HDR hdrStyle
    class FE_L,FE_F,FE_U,FE_S,FE_H feStyle
    class BE_L,BE_F,BE_D,BE_L2,BE_H beStyle
    class DB_A,DB_H,DB_S dbStyle
    class DEV_S,DEV_C,DEV_R,DEV_M devStyle
