flowchart TD
    classDef roleStyle  fill:#D6EAF8,stroke:#1A5276,color:#0A2035,stroke-width:2px
    classDef gateStyle  fill:#FEF9E7,stroke:#D4AC0D,color:#3D2B00,stroke-width:2px
    classDef allowStyle fill:#D5F5E3,stroke:#1E6823,color:#0A2D0F,stroke-width:2px
    classDef denyStyle  fill:#FADBD8,stroke:#C0392B,color:#1A0808,stroke-width:2px
    classDef auditStyle fill:#F5EEF8,stroke:#512E5F,color:#2C0A3A,stroke-width:2px

    subgraph ROLES["Authenticated User Roles"]
        R1["Admin"]
        R2["Procurement · Finance\nCompliance · Delivery Manager"]
        R3["Leadership · CXO · Partner\nDirector · Associate Director\nManager · Consultant"]
    end

    GATE{"Authorization\nRole Check"}

    subgraph RESOURCES["Protected Resources"]
        RES1["Data Upload\nAdmin Only"]
        RES2["User Management\nAdmin Only"]
        RES3["Procurement · Finance\nCompliance Dashboards\nAll Business Roles"]
        RES4["Leadership Dashboard\nExec Roles + All"]
        RES5["Vendor Repository\nP2P Analytics\nAll Roles"]
    end

    DENY["403 Forbidden\nAccess Denied"]

    AUDIT["Audit Log\nAll access events recorded\nTimestamp · User · Action"]

    ROLES --> GATE
    GATE -->|"Permitted"| RESOURCES
    GATE -->|"Denied"| DENY

    R1 -->|"Full Access"| RES1
    R1 -->|"Full Access"| RES2
    R2 -->|"Primary Access"| RES3
    R3 -->|"Primary Access"| RES4
    ROLES -->|"All Roles"| RES5

    RESOURCES --> AUDIT
    DENY --> AUDIT

    class R1,R2,R3 roleStyle
    class GATE gateStyle
    class RES1,RES2,RES3,RES4,RES5 allowStyle
    class DENY denyStyle
    class AUDIT auditStyle
