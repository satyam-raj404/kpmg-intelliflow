flowchart TD
    classDef userStyle fill:#EBF5FB,stroke:#1565C0,color:#0A1E4A,stroke-width:2px
    classDef presStyle fill:#D6EAF8,stroke:#1A5276,color:#0A2035,stroke-width:2px
    classDef appStyle  fill:#D5F5E3,stroke:#1E6823,color:#0A2D0F,stroke-width:2px
    classDef dataStyle fill:#F5EEF8,stroke:#512E5F,color:#2C0A3A,stroke-width:2px
    classDef extStyle  fill:#FADBD8,stroke:#C0392B,color:#1A0808,stroke-width:2px

    subgraph USERS["Users — KPMG Internal Staff"]
        U["Procurement · Finance · Compliance\nLeadership · Admin"]
    end

    subgraph PRES["Presentation Layer\nAzure Static Web App / Vercel CDN"]
        SPA["React SPA\nDashboards · Upload · Vendor Repository\nP2P Analytics · Compliance Tracker"]
    end

    subgraph APP["Application Layer\nAzure Container Apps"]
        direction LR
        KPI_S["KPI\nService"]
        ETL_S["ETL\nService"]
        AUTH_S["Auth\nService"]
        VEND_S["Vendor\nService"]
        P2P_S["P2P\nAnalytics"]
    end

    subgraph DATA["Data Layer\nAzure Database for PostgreSQL"]
        DB[("Transactional · Analytics\nVendor · Platform")]
    end

    EXT["SAP ERP\nFile-based CSV Export"]

    U    -->|"HTTPS — Browser"| SPA
    SPA  <-->|"REST API · HTTPS/JSON"| APP
    APP  <-->|"SQL · TLS port 5432"| DATA
    EXT  -->|"CSV Upload"| ETL_S

    class U userStyle
    class SPA presStyle
    class KPI_S,ETL_S,AUTH_S,VEND_S,P2P_S appStyle
    class DB dataStyle
    class EXT extStyle
